# OpenAI — required for thesis generation, evidence classification, postmortem
OPENAI_API_KEY=sk-...

# Telegram — create via @BotFather
TELEGRAM_BOT_TOKEN=

# MemForks — run `memfork init --quick` then `memfork doctor --env`
MEMFORK_TREE_ID=
MEMFORK_PRIVATE_KEY=
MEMFORK_NETWORK=mainnet
MEMFORK_MEMWAL_ACCOUNT=
MEMFORK_MEMWAL_KEY=
MEMFORK_RELAYER_URL=https://relayer.memory.walrus.xyz

# Optional: evidence poller interval in ms (default 180000 = 3 min)
EVIDENCE_POLL_MS=180000
